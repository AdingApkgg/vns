    <item>
      <title>天选庶民的真命之选／セレクトオブリージュ／Select Oblige</title>
      <link>https://vns.saop.cc/en/p/30665/</link>
      <pubDate>Wed, 25 Sep 2024 02:44:00 +0000</pubDate>
      <guid>https://vns.saop.cc/en/p/30665/</guid>
      <description>&lt;p&gt;&lt;img class=&#34;lozad&#34; data-src=&#34;https://static.saop.cc/vns/img/selectoblige.webp&#34; data-fancybox=&#34;gallery&#34; data-caption=&#34;selectoblige&#34;
